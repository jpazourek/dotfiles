#!/bin/bash

case "$1" in
  up)
    wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
    icon="$($HOME/.local/bin/dunst-color-icon volume_up low)"
    ;;
  down)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    icon="$($HOME/.local/bin/dunst-color-icon volume_down low)"
    ;;
  *)
    echo "Usage: $0 up|down"
    exit 1
    ;;
esac

volume="$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2 * 100)}')"

dunstify -a volume -r 9000 -u low -I "$icon" -h int:value:"$volume" "Volume" "${volume}%"
