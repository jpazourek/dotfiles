#!/bin/bash

case "$1" in
  up)
    brightnessctl set 5%+
    icon=$($HOME/.local/bin/dunst-color-icon brightness_up low)
    ;;
  down)
    brightnessctl set 5%-
    icon=$($HOME/.local/bin/dunst-color-icon brightness_down low)
    ;;
  *)
    echo "Usage: $0 up|down"
    exit 1
    ;;
esac

brightness="$(brightnessctl -m | awk -F, '{print substr($4, 0, length($4) - 1)}')"

dunstify -a brightness_monitor -r 9001 -u low -I "$icon" -h int:value:"$brightness" "Brightness" "${brightness}%"
